# Sonsam Saving API — environment template
# Copy to `.env` and fill in real values. NEVER commit the real `.env` (it is gitignored).

# ─────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────
# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/sonsam?schema=public"

# Port the HTTP server listens on. The Android app (emulator) expects 3000.
PORT=3000

# "development" | "production". Affects prod-only gates (e.g. test-push endpoint).
NODE_ENV=development

# Comma-separated list of allowed CORS origins. Leave empty to allow all in dev.
CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────
# Secret used to sign/verify JWT access tokens. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-string"

# ─────────────────────────────────────────────────────────────
# Email (OTP for registration / password reset)
# ─────────────────────────────────────────────────────────────
# Transport selection:
#   - If BREVO_API_KEY is set, email is sent via Brevo's HTTP API (HTTPS/443).
#     Use this in production / on hosts that block SMTP ports (e.g. Render).
#   - Otherwise it falls back to SMTP below (handy for local dev with Gmail).
#
# Brevo HTTP API key (https://app.brevo.com → SMTP & API → API Keys).
# The MAIL_FROM_ADDRESS below must be a VERIFIED sender in your Brevo account.
BREVO_API_KEY=

# SMTP fallback (used only when BREVO_API_KEY is empty).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your-email@gmail.com
# For Gmail use an App Password, not your account password.
MAIL_PASS=your-app-password
MAIL_FROM_NAME=Sonsam Saving
MAIL_FROM_ADDRESS=your-email@gmail.com

# ─────────────────────────────────────────────────────────────
# Push notifications (Firebase Admin) — SERVER SECRET
# ─────────────────────────────────────────────────────────────
# Base64 of the Firebase service-account JSON. This is a PRIVATE server credential
# and must NEVER be shipped to the Android app (the app only uses google-services.json).
# Generate from the service-account .json downloaded from the Firebase Console:
#   Linux/macOS : base64 -w0 service-account.json
#   PowerShell  : [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
# The Firebase project here MUST be the same one the app's google-services.json comes from.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Set to "true" to allow POST /api/notifications/test in production. In development the
# test endpoint is always enabled. Leave unset/false for real production.
PUSH_TEST_ENABLED=false
